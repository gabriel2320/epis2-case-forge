# Case Forge — variables de entorno (copiar a .env)

# Catálogo PostgreSQL (CASE-FORGE-06)
# DATABASE_URL=postgresql://case_forge:case_forge@127.0.0.1:5434/case_forge

# Traducción (CASE-FORGE-03) — usar API con tier L0_synthetic solamente
# DEEPL_API_KEY=
# TRANSLATE_PROVIDER=deepl

# Ruta local del monorepo EPIS2 para export CLI
# EPIS2_REPO_PATH=../epis2

# Harvest
# HARVEST_CACHE_DIR=.harvest-cache
# HARVEST_RATE_LIMIT_PER_MIN=30
